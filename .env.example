# Copy to .env and adjust. These defaults are for local development only.

# PostgreSQL admin settings used by docker-compose.yml for local database startup.
# Do not use this admin user as the runtime user for the MCP server.
POSTGRES_DB=agentdata
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Runtime connection string used by the MCP server.
# This role is created by scripts/load_titanic.py during local setup.
# It must be SELECT-only and must not be the PostgreSQL admin user.
DATABASE_URL=postgresql://gateway_reader:gateway_reader_dev_password@localhost:5432/agentdata

# Gateway settings

# MAX_ROWS must be positive and <= 10000.
MAX_ROWS=200

# STATEMENT_TIMEOUT_MS must be positive and <= 60000.
STATEMENT_TIMEOUT_MS=5000

# LOG_LEVEL must be one of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO
