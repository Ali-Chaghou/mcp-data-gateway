# Copy to .env and adjust. These defaults are for local development only.

# PostgreSQL (used by docker-compose.yml and the server)
POSTGRES_DB=agentdata
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Connection string the gateway uses. In M2 this switches to a dedicated
# SELECT-only role created by scripts/load_titanic.py.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentdata

# Gateway settings
GATEWAY_STATEMENT_TIMEOUT_MS=5000
GATEWAY_MAX_ROWS=200
