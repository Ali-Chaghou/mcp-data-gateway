# Secrets and local environments — never in the build context
.env
.venv/

# VCS and CI
.git/
.github/

# Python bytecode and packaging artifacts
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Editors / OS
.idea/
.vscode/
.DS_Store

# Local artifacts, data, and media
data/
screenshots/
*.png
*.jpg
.claude/

# Not needed inside the image (only pyproject.toml, README.md, src/ are copied)
tests/
docs/
scripts/
Makefile
docker-compose.yml
.pre-commit-config.yaml
